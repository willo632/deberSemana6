@model Restaurante.Models.OrdenModel

@{
    ViewData["Title"] = "Detalle de orden";
}

<h1>Detalle de orden</h1>

<dl class="row">
    <dt class="col-sm-2">Orden</dt>
    <dd class="col-sm-10">#@Model.Id</dd>
    <dt class="col-sm-2">Fecha</dt>
    <dd class="col-sm-10">@Model.FechaOrden.ToString("g")</dd>
    <dt class="col-sm-2">Cliente</dt>
    <dd class="col-sm-10">
        @($"{Model.Cliente?.Nombre} {Model.Cliente?.Apellido}")
    </dd>
    <dt class="col-sm-2">Subtotal</dt>
    <dd class="col-sm-10">@Model.Subtotal.ToString("C")</dd>
    <dt class="col-sm-2">IVA</dt>
    <dd class="col-sm-10">@Model.Iva.ToString("C")</dd>
    <dt class="col-sm-2">Total</dt>
    <dd class="col-sm-10">@Model.Total.ToString("C")</dd>
</dl>

<h4>Menus ordenados</h4>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Menu</th>
            <th>Cantidad</th>
            <th>Precio unitario</th>
            <th>Subtotal</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var detalle in Model.DetallesOrden)
        {
            <tr>
                <td>@detalle.Menu?.Nombre</td>
                <td>@detalle.Cantidad</td>
                <td>@detalle.PrecioUnitario.ToString("C")</td>
                <td>@detalle.Subtotal.ToString("C")</td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-secondary">Volver</a>
