@model Restaurante.Models.ClienteModel

@{
    ViewData["Title"] = "Detalles del Cliente";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="mb-1">
                        <i class="bi bi-person-circle text-primary me-2"></i>Detalles del Cliente
                    </h2>
                    <p class="text-muted mb-0">Información completa del cliente</p>
                </div>
                <div>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary me-2">
                        <i class="bi bi-pencil-square"></i> Editar
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Volver
                    </a>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-info-circle me-2"></i>Información Personal
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <!-- Cédula -->
                        <div class="col-md-6">
                            <div class="border-start border-primary border-4 ps-3 py-2">
                                <label class="text-muted small mb-1">Cédula</label>
                                <p class="h5 mb-0">@Model.Cedula</p>
                            </div>
                        </div>

                        <!-- Nombre -->
                        <div class="col-md-6">
                            <div class="border-start border-primary border-4 ps-3 py-2">
                                <label class="text-muted small mb-1">Nombre</label>
                                <p class="h5 mb-0">@Model.Nombre</p>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border-start border-primary border-4 ps-3 py-2">
                                <label class="text-muted small mb-1">Apellido</label>
                                <p class="h5 mb-0">@Model.Apellido</p>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="border-start border-primary border-4 ps-3 py-2">
                                <label class="text-muted small mb-1">Correo Electrónico</label>
                                <p class="h5 mb-0">
                                    <a href="mailto:@Model.Email" class="text-decoration-none">
                                        <i class="bi bi-envelope"></i> @Model.Email
                                    </a>
                                </p>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="border-start border-primary border-4 ps-3 py-2">
                                <label class="text-muted small mb-1">Teléfono</label>
                                <p class="h5 mb-0">
                                    <a href="tel:@Model.Telefono" class="text-decoration-none">
                                        <i class="bi bi-telephone"></i> @Model.Telefono
                                    </a>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
}
